# EmailJS Configuration Template
# Create a copy of this file named '.env' and fill in your EmailJS credentials.

# Your EmailJS Service ID (e.g., service_xxxyyy)
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# Your EmailJS Template ID (e.g., template_xxxyyy)
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here

# Your EmailJS Public Key (User ID) (found in Account > API Keys)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# The recipient email address configured in your EmailJS template (e.g., rkokane529@gmail.com)
VITE_EMAILJS_TO_EMAIL=rkokane529@gmail.com
